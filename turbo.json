{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"AWS_ACCESS_KEY_ID",
		"AWS_SECRET_ACCESS_KEY",
		"AWS_SESSION_TOKEN",
		"AWS_DEFAULT_REGION",
		"AWS_ACCOUNT",
		"AWS_REGION",
		"AWS_PROFILE",
		"USER"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "cdk.out/**"]
		},
		"deploy": {
			"cache": false,
			"dependsOn": ["synth"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^build"]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"lint:fix": {
			"dependsOn": ["^build"]
		},
		"synth": {
			"dependsOn": ["build"]
		},
		"test": {
			"dependsOn": ["^build"]
		}
	}
}
