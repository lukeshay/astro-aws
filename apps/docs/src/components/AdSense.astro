---
interface Props {
	adSlot: string;
}

const { adSlot } = Astro.props;
---

<ins
	class="adsbygoogle"
	style="display:block;min-height:90px;"
	data-ad-client="ca-pub-1372217439158608"
	data-ad-slot={adSlot}
	data-ad-format="auto"
	data-full-width-responsive="true"></ins>
<script
	async
	src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1372217439158608"
	crossorigin="anonymous"></script>
<script is:inline>
	(function() {
		var checkAd = setInterval(function() {
			if (typeof window.adsbygoogle !== 'undefined') {
				clearInterval(checkAd);
				try {
					(adsbygoogle = window.adsbygoogle || []).push({});
				} catch(e) {}
			}
		}, 100);
	})();
</script>